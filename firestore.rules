rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, role (student/teacher), className, school
    //
    // Collection: exams
    // Fields: id, title, creatorId, type (ai/upload), questions, createdAt
    //
    // Collection: attempts
    // Fields: id, userId, examId, score, totalQuestions, timeSpent, answers, date, teacherComment
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "binhanchau2000@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function isStudent() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'student';
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && request.resource.data.role in ['student', 'teacher'];
      allow update: if isOwner(userId) || isAdmin();
    }

    // Exam Rules
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update: if (isTeacher() && resource.data.creatorId == request.auth.uid) || isAdmin();
      allow delete: if (isTeacher() && resource.data.creatorId == request.auth.uid) || isAdmin();
    }

    // Attempt Rules
    match /attempts/{attemptId} {
      allow read: if isOwner(resource.data.userId) || isTeacher() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isTeacher() || isAdmin(); // For comments
    }
  }
}
